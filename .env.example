# LLM プロバイダ: local(既定) | openai | gemini | claude | copilot
LLM_PROVIDER=local
# 埋め込みプロバイダ: local(既定) | openai | gemini | copilot  (claude は埋め込み非対応)
EMBED_PROVIDER=local

# --- モデル名 (省略時はプロバイダ毎の既定値) ---
# local 例: LLM_MODEL=qwen2.5:7b  /  EMBED_MODEL=bge-m3:latest
# openai 例: LLM_MODEL=gpt-4o-mini / EMBED_MODEL=text-embedding-3-small
# gemini 例: LLM_MODEL=gemini-2.0-flash / EMBED_MODEL=gemini-embedding-001
# claude 例: LLM_MODEL=claude-3-5-haiku-latest  (埋め込みは EMBED_PROVIDER 側)
# copilot 例: LLM_MODEL=gpt-4o / EMBED_MODEL=text-embedding-3-small
# LLM_MODEL=
# EMBED_MODEL=
# EMBED_DIM は通常不要。未設定なら EMBED_MODEL の次元を自動検出する。
# 明示したい / 自動検出に失敗する場合のみ設定 (例: bge-m3=1024, nomic=768, OpenAI=1536)
# EMBED_DIM=

# 保存先と Ollama ホスト
WORKING_DIR=./rag_storage
OLLAMA_HOST=http://localhost:11434

# API キー (クラウド利用時のみ)
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=

# GitHub Copilot を使う場合 (LLM_PROVIDER=copilot / EMBED_PROVIDER=copilot)
# COPILOT_TOKEN=
# COPILOT_BASE_URL=https://api.githubcopilot.com
# COPILOT_INTEGRATION_ID=vscode-chat
# COPILOT_EDITOR_VERSION=vscode/1.95.0
